# NeuroDB configuration — copy to `.env` and adjust for your deployment.
# All variables are optional unless noted.

# --- Security (internet-facing defaults) ---
# Require this key on all data routes. Generate one, e.g.:  openssl rand -hex 32
NEURODB_API_KEY=change-me
# Set to 1 ONLY to run without auth (the server refuses to start otherwise).
# NEURODB_ALLOW_ANONYMOUS=0
# Comma-separated allowed CORS origins (empty = no cross-origin).
NEURODB_CORS_ORIGINS=https://your-frontend.example
# Per-client request budget per minute (0 disables).
NEURODB_RATE_LIMIT_PER_MINUTE=600
# Reject request bodies larger than this many bytes (default 8 MiB).
NEURODB_MAX_REQUEST_BYTES=8388608

# --- Storage / durability ---
NEURODB_DATA_FILE=/data/neurodb.npz
NEURODB_AUTOSAVE_INTERVAL=5
# Fail startup on a corrupt data file instead of quarantining + starting empty.
NEURODB_FAIL_ON_CORRUPT_LOAD=0

# --- Server ---
NEURODB_HOST=0.0.0.0
NEURODB_PORT=8000
NEURODB_EMBEDDING_DIM=256
NEURODB_LOG_LEVEL=info
NEURODB_LOG_FORMAT=json
